# --- Prerequisites / Build Systems ---
# Ignore the entire build directory where CMake/Make outputs files
build/
bin/
lib/
obj/

# --- Compiled Files ---
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
*.out

# --- OSM & Large Data Files (CRITICAL) ---
# Never upload raw map data or large cost matrices to GitHub
*.pbf
*.osm
*.xml
*.csv
*.log
data/raw/
data/processed/

# --- IDE Specifics ---
# Visual Studio Code
.vscode/
# CLion / JetBrains
.idea/
cmake-build-*/
# Visual Studio
.vs/
Debug/
Release/
x64/

# --- OS Generated Files ---
.DS_Store
Thumbs.db

# --- Python (if using for scripts/plotting) ---
__pycache__/
*.pyc
venv/